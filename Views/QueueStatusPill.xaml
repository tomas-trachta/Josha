<UserControl x:Class="Josha.Views.QueueStatusPill"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Josha.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="24" d:DesignWidth="180">
    <Grid>
        <ToggleButton x:Name="PillToggle"
                      Padding="10,2"
                      Background="{StaticResource Brush.AccentSubtle}"
                      Foreground="{StaticResource Brush.OnSurface}"
                      BorderBrush="{StaticResource Brush.Outline}"
                      BorderThickness="1"
                      Cursor="Hand"
                      Visibility="Collapsed">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </ToggleButton.Template>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="7" Height="7"
                         Margin="0,0,6,0"
                         Fill="{StaticResource Brush.Status.Pending}"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="PillText"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.OnSurface}"/>
            </StackPanel>
        </ToggleButton>

        <Popup x:Name="JobsPopup"
               IsOpen="{Binding IsChecked, ElementName=PillToggle}"
               Placement="Top"
               PlacementTarget="{Binding ElementName=PillToggle}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{StaticResource Brush.SurfaceElevated}"
                    BorderBrush="{StaticResource Brush.Outline}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Effect="{StaticResource Elevation.3}"
                    Width="460"
                    MaxHeight="380">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource Brush.SurfaceMuted}"
                            BorderBrush="{StaticResource Brush.OutlineSubtle}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="File operations"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.OnSurface}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Clear finished"
                                    Click="OnClearFinishedClick"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    FontSize="10"
                                    Padding="6,1"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="JobsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:QueueJobViewModel}">
                                    <Border BorderBrush="{StaticResource Brush.OutlineSubtle}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding KindLabel}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Foreground="{StaticResource Brush.OnSurfaceMuted}"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource Brush.OnSurface}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StatusLabel}"
                                                           FontSize="11"
                                                           Margin="8,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding StatusBrushKey, Converter={StaticResource ResKeyToBrush}}"/>
                                                <Button Grid.Column="3"
                                                        Content="Retry"
                                                        Command="{Binding RetryCommand}"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Padding="6,2"
                                                        FontSize="10"
                                                        Margin="0,0,4,0"
                                                        Visibility="{Binding IsRetryable, Converter={StaticResource BoolToVis}}"/>
                                                <Button Grid.Column="3"
                                                        Content="Cancel"
                                                        Command="{Binding CancelCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="6,2"
                                                        FontSize="10"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>
                                            <ProgressBar Grid.Row="1"
                                                         Height="3"
                                                         Margin="0,4,0,0"
                                                         Minimum="0" Maximum="1"
                                                         Value="{Binding ProgressFraction, Mode=OneWay}"
                                                         IsIndeterminate="False"
                                                         Background="{StaticResource Brush.OutlineSubtle}"
                                                         Foreground="{StaticResource Brush.Accent}"
                                                         BorderThickness="0"/>
                                            <Grid Grid.Row="2" Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding ErrorMessage}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource Brush.Status.Error}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ProgressDisplay}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource Brush.OnSurfaceMuted}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
