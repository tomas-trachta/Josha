<Window x:Class="Josha.Views.SiteManagerSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sites"
        Width="560" Height="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.Surface}"
        Foreground="{StaticResource Brush.OnSurface}"
        FontFamily="{DynamicResource Font.Body}">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="OnCancelCommand"/>
    </Window.CommandBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Saved sites"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceMuted}"
                BorderBrush="{StaticResource Brush.OutlineSubtle}"
                BorderThickness="1"
                CornerRadius="3">
            <ListBox x:Name="SiteList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource Brush.OnSurface}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource Brush.OnSurfaceMuted}">
                                    <Run Text="{Binding Username, Mode=OneWay}"/><Run Text="@"/><Run Text="{Binding Host, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Protocol, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="New…" Click="OnNew"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="90" Margin="0,0,8,0"/>
            <Button Content="Edit" Click="OnEdit"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="90" Margin="0,0,8,0"/>
            <Button Content="Delete" Click="OnDelete"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="90" Margin="0,0,16,0"/>
            <Button Content="Cancel" Click="OnCancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="90" Margin="0,0,8,0"/>
            <Button Content="Connect" Click="OnConnect"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="100" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
