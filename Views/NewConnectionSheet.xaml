<Window x:Class="Josha.Views.NewConnectionSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:Josha.Models"
        mc:Ignorable="d"
        Title="New connection"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Surface}"
        Foreground="{StaticResource Brush.OnSurface}"
        FontFamily="{DynamicResource Font.Body}">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="OnCancelCommand"/>
    </Window.CommandBindings>

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.OnSurfaceMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="New connection" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Host" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="HostBox" Style="{StaticResource ModernTextBoxStyle}" MinHeight="28"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="PortBox" Style="{StaticResource ModernTextBoxStyle}" MinHeight="28"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Protocol" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="ProtocolBox" Style="{StaticResource ModernComboBoxStyle}"
                      SelectionChanged="OnProtocolChanged" MinHeight="28">
                <ComboBoxItem Tag="Ftp" Content="FTP (plain, port 21)"/>
                <ComboBoxItem Tag="FtpsExplicit" Content="FTPS — explicit AUTH TLS (port 21)"/>
                <ComboBoxItem Tag="FtpsImplicit" Content="FTPS — implicit (port 990)"/>
                <ComboBoxItem Tag="Sftp" Content="SFTP — SSH (port 22)"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="UserBox" Style="{StaticResource ModernTextBoxStyle}" MinHeight="28"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <PasswordBox x:Name="PasswordBox" MinHeight="28"
                                 Background="{StaticResource Brush.SurfaceMuted}"
                                 Foreground="{StaticResource Brush.OnSurface}"
                                 BorderBrush="{StaticResource Brush.Outline}"
                                 BorderThickness="1"
                                 Padding="6,4"/>
                    <TextBox x:Name="PasswordPlain" MinHeight="28"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Visibility="Collapsed"/>
                </Grid>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,2">
                <CheckBox x:Name="ShowPasswordCheck" Content="Show"
                          Foreground="{StaticResource Brush.OnSurfaceMuted}"
                          Click="OnTogglePasswordReveal"
                          Padding="4,0,0,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Start directory" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="StartDirBox" Text="/" Style="{StaticResource ModernTextBoxStyle}" MinHeight="28"/>
        </StackPanel>

        <Grid Grid.Row="6" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Encoding" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="EncodingBox" Text="UTF-8" Style="{StaticResource ModernTextBoxStyle}" MinHeight="28"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Mode (FTP only)" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="ModeBox" Style="{StaticResource ModernComboBoxStyle}" MinHeight="28">
                    <ComboBoxItem Tag="Passive" Content="Passive (PASV)" IsSelected="True"/>
                    <ComboBoxItem Tag="Active" Content="Active (PORT)"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="TLS validation" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="TlsBox" Style="{StaticResource ModernComboBoxStyle}" MinHeight="28">
                    <ComboBoxItem Tag="Strict" Content="Strict" IsSelected="True"/>
                    <ComboBoxItem Tag="AcceptOnFirstUse" Content="Trust on first use"/>
                    <ComboBoxItem Tag="AcceptAny" Content="Accept any (insecure)"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="7" Margin="0,4,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="SaveSiteCheck" Grid.Column="0"
                      Content="Save to sites as"
                      Foreground="{StaticResource Brush.OnSurface}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Click="OnSaveSiteToggle"/>
            <TextBox x:Name="SiteNameBox" Grid.Column="1"
                     Style="{StaticResource ModernTextBoxStyle}"
                     IsEnabled="False"
                     MinHeight="26"/>
        </Grid>

        <Border Grid.Row="8"
                Padding="10,6"
                Margin="0,0,0,12"
                Background="{StaticResource Brush.SurfaceMuted}"
                BorderBrush="{StaticResource Brush.OutlineSubtle}"
                BorderThickness="1"
                CornerRadius="3"
                Visibility="{Binding TestVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
            <TextBlock x:Name="TestResultText"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Test connection"
                    Click="OnTestConnection"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="120" Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Click="OnCancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="100" Margin="0,0,8,0"/>
            <Button Content="Connect"
                    Click="OnConnect"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="100" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
