<Window x:Class="Josha.Views.BookmarksDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Josha.ViewModels"
        xmlns:models="clr-namespace:Josha.Models"
        mc:Ignorable="d"
        Title="Bookmarks"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.Surface}"
        Foreground="{StaticResource Brush.OnSurface}"
        FontFamily="{DynamicResource Font.Body}"
        d:DataContext="{d:DesignInstance Type=vm:AppShellViewModel}">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="OnClose"/>
    </Window.CommandBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Bookmarks"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource Brush.OutlineSubtle}"
                BorderThickness="1"
                CornerRadius="4">
            <ListBox x:Name="BookmarkList"
                     ItemsSource="{Binding Bookmarks}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnRowDoubleClick"
                     KeyDown="OnListKeyDown">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.AccentSubtle}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Bookmark}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.OnSurface}"/>
                                <TextBlock Text="{Binding TargetPath}" FontSize="11"
                                           Foreground="{StaticResource Brush.OnSurfaceMuted}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="&#xE10A;"
                                    Tag="{Binding}"
                                    Click="OnRemoveClick"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="11"
                                    Foreground="{StaticResource Brush.OnSurfaceMuted}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Width="24" Height="24"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    ToolTip="Remove bookmark"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   FontSize="11"
                   Foreground="{StaticResource Brush.OnSurfaceMuted}"
                   Text="Enter / double-click → open · Esc → close · Ctrl+D in a pane → add"/>
    </Grid>
</Window>
