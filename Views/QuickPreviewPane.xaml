<UserControl x:Class="Josha.Views.QuickPreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Josha.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FilePreviewViewModel}"
             d:DesignHeight="400" d:DesignWidth="280">
    <Border Background="{StaticResource Brush.SurfaceMuted}"
            BorderBrush="{StaticResource Brush.OutlineSubtle}"
            BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10,6"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.OutlineSubtle}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding Title, FallbackValue='(no selection)'}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <Grid Grid.Row="1">
                <!-- Empty state -->
                <TextBlock Text="Select a file to preview"
                           Foreground="{StaticResource Brush.OnSurfaceMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource Brush.SurfaceSunken}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Text">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <TextBox Text="{Binding TextContent, Mode=OneWay}"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource Brush.OnSurface}"
                             FontFamily="Cascadia Mono, Consolas, Courier New"
                             FontSize="11"
                             Padding="8"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"/>
                </ScrollViewer>

                <Grid Background="{StaticResource Brush.SurfaceSunken}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Image Source="{Binding ImageContent}"
                           Stretch="Uniform"
                           Margin="8"/>
                </Grid>

                <TextBlock Foreground="{StaticResource Brush.OnSurfaceMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="11"
                           Margin="20"
                           Text="{Binding SubtitleText}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Unsupported">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Error">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.OutlineSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="10,4">
                <TextBlock Text="{Binding SubtitleText}"
                           Foreground="{StaticResource Brush.OnSurfaceMuted}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
