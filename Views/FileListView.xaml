<UserControl x:Class="Josha.Views.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Josha.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FileListViewModel}"
             d:DesignHeight="360" d:DesignWidth="600">
    <UserControl.Resources>
        <Style x:Key="ListColumnHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.OnSurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.OutlineSubtle}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfacePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="ListItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <!-- Two-way binding so programmatic row.IsSelected toggles
                 (pattern-select, invert) propagate into the ListView's
                 native selection state. Reverse direction keeps the VM
                 in sync with mouse / keyboard selection. -->
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.AccentSubtle}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="6,4"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.OutlineSubtle}"
                BorderThickness="0,0,0,1">
            <TextBox x:Name="FilterBox"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Tag="Filter (Ctrl+F) — substring or glob (*.cs)"
                     MinHeight="26"
                     KeyDown="OnFilterKeyDown"/>
        </Border>

        <ListView x:Name="MainList" Grid.Row="1"
                  ItemsSource="{Binding RowsView}"
                  ItemContainerStyle="{StaticResource ListItemStyle}"
                  SelectionMode="Extended"
                  Background="{StaticResource Brush.Surface}"
                  Foreground="{StaticResource Brush.OnSurface}"
                  BorderThickness="0"
                  ScrollViewer.IsDeferredScrollingEnabled="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  GridViewColumnHeader.Click="OnHeaderClick"
                  MouseDoubleClick="OnRowDoubleClick"
                  KeyDown="OnListKeyDown"
                  SelectionChanged="OnSelectionChanged"
                  PreviewMouseLeftButtonDown="OnListPreviewMouseDown"
                  PreviewMouseLeftButtonUp="OnListPreviewMouseUp"
                  MouseMove="OnListMouseMove"
                  PreviewMouseRightButtonUp="OnListPreviewMouseRightButtonUp">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ListColumnHeaderStyle}">
                    <GridViewColumn Width="320">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Name" Content="Name"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsEditing, Converter={StaticResource InvBoolToVis}}">
                                        <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                                    Foreground="{Binding IconBrushKey, Converter={StaticResource ResKeyToBrush}}"
                                                                    Width="14" Height="14"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.RowFolder}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBox Text="{Binding Name, Mode=OneTime}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                             Style="{StaticResource ModernTextBoxStyle}"
                                             MinHeight="24"
                                             Padding="4,0"
                                             KeyDown="OnRenameEditorKeyDown"
                                             IsVisibleChanged="OnRenameEditorVisibleChanged"/>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="60" DisplayMemberBinding="{Binding Extension}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Extension" Content="Ext"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="100">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Size" Content="Size"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeDisplay}"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource Brush.OnSurface}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding ModifiedDisplay}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Modified" Content="Modified"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="100">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Modified" Content="Age"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AgeDisplay}"
                                           Foreground="{Binding AgeBrushKey, Converter={StaticResource ResKeyToBrush}}"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2"
                Background="{StaticResource Brush.SurfaceMuted}"
                BorderBrush="{StaticResource Brush.OutlineSubtle}"
                BorderThickness="0,1,0,0"
                Padding="10,6"
                Visibility="{Binding LoadError, Converter={StaticResource StrNotEmptyToVis}}">
            <TextBlock Text="{Binding LoadError}"
                       Foreground="{StaticResource Brush.OnSurfaceMuted}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>
        </Border>
    </Grid>
</UserControl>
