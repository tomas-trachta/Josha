<UserControl x:Class="Josha.Views.FilePaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Josha.ViewModels"
             xmlns:views="clr-namespace:Josha.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FilePaneViewModel}"
             d:DesignHeight="500" d:DesignWidth="600">
    <Border x:Name="ActiveBorder"
            BorderThickness="2" CornerRadius="4" Margin="2"
            BorderBrush="{StaticResource Brush.TreeBorderInactive}"
            SnapsToDevicePixels="True"
            AllowDrop="True"
            DragEnter="OnDragEnter"
            DragOver="OnDragOver"
            DragLeave="OnDragLeave"
            Drop="OnDrop">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Visibility="{Binding IsRemote, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource Brush.SurfaceMuted}"
                    BorderBrush="{StaticResource Brush.OutlineSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="10,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Fill="{Binding ConnectionStatusBrushKey, Converter={StaticResource ResKeyToBrush}}"/>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{StaticResource Brush.OnSurfaceMuted}"
                               FontSize="11"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Foreground="{StaticResource Brush.OnSurface}"
                               FontSize="11"
                               VerticalAlignment="Center">
                        <Run Text="{Binding Site.Username, Mode=OneWay}"/><Run Text="@"/><Run Text="{Binding Site.Host, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Content="Reconnect"
                            Margin="16,0,0,0"
                            Padding="10,3"
                            Click="OnReconnectClick"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="11"/>
                </StackPanel>
            </Border>

            <views:DriveBarControl Grid.Row="1" DataContext="{Binding}"
                                   Visibility="{Binding IsRemote, Converter={StaticResource InvBoolToVis}}"/>

            <views:PathBarControl Grid.Row="2" DataContext="{Binding}"/>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="PreviewColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                <views:FileListView x:Name="ListViewControl"
                                    DataContext="{Binding List}"
                                    Visibility="{Binding DataContext.IsListMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

                <views:FileTilesView x:Name="TilesViewControl"
                                     DataContext="{Binding List}"
                                     Visibility="{Binding DataContext.IsTilesMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

                <Grid Visibility="{Binding IsDiskUsageMode, Converter={StaticResource BoolToVis}}">
                    <Grid Visibility="{Binding HasDiskUsageRoot, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.OutlineSubtle}"
                                BorderThickness="0,0,0,1"
                                Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton Grid.Column="0"
                                              IsChecked="{Binding IsTreeScrollMode}"
                                              MinHeight="26" Width="36"
                                              Margin="0,0,6,0"
                                              ToolTip="Toggle scroll/drag (off = click-drag pan, on = mouse wheel scrolls). Ctrl+wheel zooms in either mode.">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.OnSurfaceMuted}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Outline}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Content" Value="&#xE7C9;"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{DynamicResource Brush.SurfaceHover}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{DynamicResource Brush.AccentSubtle}"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                                        Value="{DynamicResource Brush.Accent}"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource Brush.Accent}"/>
                                                                <Setter Property="Content" Value="&#xE70F;"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.Resources>
                                        <Style x:Key="DiskUsageSearchResultItemStyle" TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                Padding="{TemplateBinding Padding}"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{DynamicResource Brush.SurfaceHover}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{DynamicResource Brush.AccentSubtle}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <DataTemplate x:Key="DiskUsageSearchResultTemplate">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource Brush.OnSurface}"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding LocationPath}"
                                                               Foreground="{DynamicResource Brush.OnSurfaceMuted}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource Brush.SurfaceMuted}"
                                                        BorderBrush="{DynamicResource Brush.OutlineSubtle}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="6,1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               Foreground="{DynamicResource Brush.OnSurfaceMuted}"
                                                               FontSize="10"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </Grid.Resources>

                                    <Grid Grid.Column="0" Margin="0,0,4,0">
                                        <TextBox x:Name="AllSearchBox"
                                                 Text="{Binding AllSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Tag="Search all…"
                                                 MinHeight="26"
                                                 KeyDown="OnDiskUsageSearchBoxKeyDown"/>
                                        <Popup PlacementTarget="{Binding ElementName=AllSearchBox}"
                                               Placement="Bottom"
                                               IsOpen="{Binding HasAllSearchResults, Mode=OneWay}"
                                               AllowsTransparency="True"
                                               StaysOpen="True"
                                               PopupAnimation="Fade"
                                               Width="{Binding ElementName=AllSearchBox, Path=ActualWidth}">
                                            <Border Background="{DynamicResource Brush.SurfaceElevated}"
                                                    BorderBrush="{DynamicResource Brush.Outline}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Effect="{StaticResource Elevation.2}"
                                                    MaxHeight="360">
                                                <ListBox x:Name="AllSearchResultsList"
                                                         ItemsSource="{Binding AllSearchResults}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ItemContainerStyle="{StaticResource DiskUsageSearchResultItemStyle}"
                                                         ItemTemplate="{StaticResource DiskUsageSearchResultTemplate}"
                                                         MouseDoubleClick="OnDiskUsageSearchResultActivated"
                                                         KeyDown="OnDiskUsageSearchResultsKeyDown"/>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <Grid Grid.Column="1" Margin="2,0,2,0">
                                        <TextBox x:Name="FilesSearchBox"
                                                 Text="{Binding FilesSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Tag="Files only…"
                                                 MinHeight="26"
                                                 KeyDown="OnDiskUsageSearchBoxKeyDown"/>
                                        <Popup PlacementTarget="{Binding ElementName=FilesSearchBox}"
                                               Placement="Bottom"
                                               IsOpen="{Binding HasFilesSearchResults, Mode=OneWay}"
                                               AllowsTransparency="True"
                                               StaysOpen="True"
                                               PopupAnimation="Fade"
                                               Width="{Binding ElementName=FilesSearchBox, Path=ActualWidth}">
                                            <Border Background="{DynamicResource Brush.SurfaceElevated}"
                                                    BorderBrush="{DynamicResource Brush.Outline}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Effect="{StaticResource Elevation.2}"
                                                    MaxHeight="360">
                                                <ListBox x:Name="FilesSearchResultsList"
                                                         ItemsSource="{Binding FilesSearchResults}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ItemContainerStyle="{StaticResource DiskUsageSearchResultItemStyle}"
                                                         ItemTemplate="{StaticResource DiskUsageSearchResultTemplate}"
                                                         MouseDoubleClick="OnDiskUsageSearchResultActivated"
                                                         KeyDown="OnDiskUsageSearchResultsKeyDown"/>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <Grid Grid.Column="2" Margin="4,0,0,0">
                                        <TextBox x:Name="FoldersSearchBox"
                                                 Text="{Binding FoldersSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Tag="Folders only…"
                                                 MinHeight="26"
                                                 KeyDown="OnDiskUsageSearchBoxKeyDown"/>
                                        <Popup PlacementTarget="{Binding ElementName=FoldersSearchBox}"
                                               Placement="Bottom"
                                               IsOpen="{Binding HasFoldersSearchResults, Mode=OneWay}"
                                               AllowsTransparency="True"
                                               StaysOpen="True"
                                               PopupAnimation="Fade"
                                               Width="{Binding ElementName=FoldersSearchBox, Path=ActualWidth}">
                                            <Border Background="{DynamicResource Brush.SurfaceElevated}"
                                                    BorderBrush="{DynamicResource Brush.Outline}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Effect="{StaticResource Elevation.2}"
                                                    MaxHeight="360">
                                                <ListBox x:Name="FoldersSearchResultsList"
                                                         ItemsSource="{Binding FoldersSearchResults}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ItemContainerStyle="{StaticResource DiskUsageSearchResultItemStyle}"
                                                         ItemTemplate="{StaticResource DiskUsageSearchResultTemplate}"
                                                         MouseDoubleClick="OnDiskUsageSearchResultActivated"
                                                         KeyDown="OnDiskUsageSearchResultsKeyDown"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <views:TreeGraphControl x:Name="DiskUsageTree"
                                                Grid.Row="1"
                                                RootItem="{Binding DiskUsageRoot}"
                                                IsActive="{Binding IsActive}"
                                                ShowSizes="True"
                                                IsScrollMode="{Binding IsTreeScrollMode}"/>
                    </Grid>

                    <Border Background="{StaticResource Brush.SurfaceMuted}"
                            Visibility="{Binding IsScanningDrive, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                            <TextBlock Text="Scanning…"
                                       FontSize="20" FontWeight="Light"
                                       Foreground="{StaticResource Brush.OnSurface}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <ProgressBar IsIndeterminate="True"
                                         Height="4" Width="320"
                                         Foreground="{StaticResource Brush.Accent}"
                                         Background="{StaticResource Brush.OutlineSubtle}"
                                         BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource Brush.SurfaceMuted}"
                            Visibility="{Binding IsLoadingDiskUsage, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                            <TextBlock Text="Loading snapshot…"
                                       FontSize="20" FontWeight="Light"
                                       Foreground="{StaticResource Brush.OnSurface}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <ProgressBar IsIndeterminate="True"
                                         Height="4" Width="320"
                                         Foreground="{StaticResource Brush.Accent}"
                                         Background="{StaticResource Brush.OutlineSubtle}"
                                         BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource Brush.SurfaceMuted}"
                            Visibility="{Binding NeedsScan, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
                            <TextBlock FontSize="20" FontWeight="Light"
                                       Foreground="{StaticResource Brush.OnSurface}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6">
                                <Run Text="No disk-usage snapshot for "/>
                                <Run Text="{Binding DriveLetter, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=":"/>
                            </TextBlock>
                            <TextBlock Text="Scanning the drive builds a sized view of every folder. The first scan can take a few minutes; subsequent updates are incremental."
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.OnSurfaceMuted}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>
                            <Button Content="Scan now"
                                    Command="{Binding ScanCurrentDriveCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </Grid>

                <GridSplitter Grid.Column="1" Width="3"
                              Background="{StaticResource Brush.Outline}"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              Visibility="{Binding IsPreviewPaneVisible, Converter={StaticResource BoolToVis}}"/>

                <views:QuickPreviewPane Grid.Column="2"
                                        DataContext="{Binding CurrentPreview}"
                                        Visibility="{Binding DataContext.IsPreviewPaneVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
