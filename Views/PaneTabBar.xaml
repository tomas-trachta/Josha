<UserControl x:Class="Josha.Views.PaneTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Josha.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PaneColumnViewModel}"
             d:DesignHeight="34" d:DesignWidth="600">
    <UserControl.Resources>
        <Style x:Key="TabChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.OutlineSubtle}"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="CornerRadius" Value="4,4,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="MaxWidth" Value="200"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="CloseTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.OnSurfaceMuted}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.OutlineSubtle}"
            BorderThickness="0,0,0,1"
            Padding="6,6,6,0">
        <StackPanel Orientation="Horizontal">
            <ItemsControl x:Name="TabsHost" ItemsSource="{Binding Tabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FilePaneViewModel}">
                        <Border Tag="{Binding}"
                                MouseLeftButtonDown="OnTabClick"
                                MouseRightButtonDown="OnTabRightClick">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource TabChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentInColumn}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TabTitle}"
                                           Foreground="{StaticResource Brush.OnSurface}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Padding="10,4,4,4"
                                           ToolTip="{Binding CurrentPath}"/>
                                <Button Grid.Column="1"
                                        Content="&#xE10A;"
                                        Tag="{Binding}"
                                        Click="OnCloseClick"
                                        Style="{StaticResource CloseTabButtonStyle}"
                                        Margin="2,0,4,0"
                                        ToolTip="Close tab"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="&#xE710;"
                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                    FontSize="12"
                    Command="{Binding NewTabCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Width="28" MinHeight="26"
                    Margin="4,0,0,0"
                    ToolTip="New tab (Ctrl+T)"/>
        </StackPanel>
    </Border>
</UserControl>
