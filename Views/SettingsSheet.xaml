<Window x:Class="Josha.Views.SettingsSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Josha.ViewModels"
        mc:Ignorable="d"
        Title="Settings"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Surface}"
        Foreground="{StaticResource Brush.OnSurface}"
        FontFamily="{DynamicResource Font.Body}"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="OnCancelCommand"/>
    </Window.CommandBindings>

    <Grid Margin="22,18,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="External editor (F4)" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.OnSurface}" Margin="0,0,0,4"/>
            <TextBlock Text="Path to the program that opens files for editing. Leave blank to fall back to $JOSHA_EDITOR / $EDITOR / Notepad."
                       FontSize="11"
                       Foreground="{StaticResource Brush.OnSurfaceMuted}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding EditorPath, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Tag="e.g. C:\Program Files\Microsoft VS Code\Code.exe"
                         MinHeight="28"/>
                <Button Grid.Column="1"
                        Content="Browse…"
                        Click="OnBrowseEditorClick"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="6,0,0,0"
                        Padding="12,4"
                        MinHeight="28"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="Theme" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="System follows the Windows light/dark setting. Theme changes apply on the next launch."
                       FontSize="11"
                       Foreground="{StaticResource Brush.OnSurfaceMuted}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding Theme}"
                      MinHeight="28"
                      MaxWidth="220"
                      HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="Default view mode for new tabs" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding ViewModeOptions}"
                      SelectedItem="{Binding DefaultViewMode}"
                      MinHeight="28"
                      MaxWidth="220"
                      HorizontalAlignment="Left"/>
        </StackPanel>

        <CheckBox Grid.Row="4"
                  Content="Confirm before permanent delete (Shift+F8)"
                  IsChecked="{Binding ConfirmDeletePermanent}"
                  FontSize="12"
                  Margin="0,0,0,14"
                  Foreground="{StaticResource Brush.OnSurface}"/>

        <StackPanel Grid.Row="5" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Font / UI scale" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding FontScaleDisplay}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.OnSurfaceMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Text="0.85× to 1.50×. Applies on next launch."
                       FontSize="11"
                       Foreground="{StaticResource Brush.OnSurfaceMuted}"
                       Margin="0,2,0,4"/>
            <Slider Minimum="0.85" Maximum="1.5"
                    Value="{Binding FontScale}"
                    SmallChange="0.05" LargeChange="0.1"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                    TickPlacement="None"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="100" Margin="0,0,8,0"/>
            <Button Content="Save" Click="OnSave"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="100" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
