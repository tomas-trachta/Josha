<UserControl x:Class="Josha.Views.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="34" d:DesignWidth="240">
    <Grid>
        <TextBox x:Name="InputBox"
                 Style="{StaticResource SearchTextBoxStyle}"
                 Tag="{Binding Placeholder, ElementName=Root}"
                 Text="{Binding SearchText, ElementName=Root, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 IsEnabled="{Binding IsEnabled, ElementName=Root}"
                 KeyDown="OnInputKeyDown"/>
        <Popup PlacementTarget="{Binding ElementName=InputBox}"
               Placement="Bottom"
               VerticalOffset="4"
               IsOpen="{Binding IsDropDownOpen, ElementName=Root, Mode=OneWay}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Style="{StaticResource SuggestionCardStyle}"
                    MinWidth="{Binding ActualWidth, ElementName=InputBox}">
                <ListBox ItemsSource="{Binding ItemsSource, ElementName=Root}"
                         SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MaxHeight="380">
                    <ListBox.Resources>
                        <!-- Compact, hover-tinted, rounded item template
                             matching the ComboBox item visual. -->
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="2,1"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="0"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background"
                                                        Value="{StaticResource Brush.SurfaceHover}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background"
                                                        Value="{StaticResource Brush.SurfaceSelected}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource SuggestionGroupHeaderStyle}"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Leading glyph: folder for directories, file for files.
                                     TypeLabel comes back as "Folder" or "File". -->
                                <TextBlock x:Name="ItemGlyph"
                                           Grid.Column="0"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{StaticResource Brush.OnSurfaceMuted}"
                                           VerticalAlignment="Center"
                                           Text="&#xE7C3;">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE7C3;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TypeLabel}" Value="Folder">
                                                    <Setter Property="Text" Value="&#xE8B7;"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{StaticResource Brush.OnSurface}"/>
                                    <TextBlock Text="{Binding LocationPath}"
                                               FontSize="11"
                                               Foreground="{StaticResource Brush.OnSurfaceSubtle}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</UserControl>
